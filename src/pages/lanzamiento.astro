---
import Layout from "../layouts/Layout.astro";

const LAUNCH_DATE = new Date("2026-05-01T20:00:00-03:00");

const socials = [
  {
    name: "Instagram",
    url: "https://www.instagram.com/theconjuntos/",
    icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
  },
  {
    name: "Spotify",
    url: "https://open.spotify.com/artist/3mTkZGDhS9Chis4tqJRCUF?si=VP5hWoOhSmab4cxVZJ8pGg",
    icon: "M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z",
  },
  {
    name: "YouTube",
    url: "https://www.youtube.com/@losconjuntos",
    icon: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
  {
    name: "TikTok",
    url: "https://vt.tiktok.com/ZSHtQ1BYJ/",
    icon: "M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z",
  },
];

const dogs = [
  { label: "ROSE", src: "/perros/@susanakorenhof.png" },
  { label: "ALBERTA", src: "/perros/@alvarosalazar7.png" },
  // { label: "@inugami_yokai", src: "/perros/@inugami_yokai.png" },
  // { label: "@jeremiagzl", src: "/perros/@jeremiagzl.png" },
  // { label: "@nahuetulian", src: "/perros/@nahuetulian.png" },
  // { label: "BECCA", src: "/perros/@paulaaminteguiaga.png" },
  // { label: "@soffia.rv", src: "/perros/@soffia.rv.png" },
  // { label: "DIEGUITO", src: "/perros/@susanakorenhof2.png" },
  { label: null, src: null },
];

const reels = [{ youtube: "ChRgtvzgpLc" }, { youtube: "mUBa5voVd48" }];

// ─── DÍA DEL LANZAMIENTO ───────────────────────────────────────────────
// Cuando salga el video: cambiar launched a true y poner el ID de YouTube.
// El ID es la parte final de la URL: youtube.com/watch?v=ESTE_ES_EL_ID
const launched = false;
const youtubeUrl = "https://www.youtube.com/watch?v=Q8Hji_hJcHQ";
const youtubeId = youtubeUrl.split('v=')[1];
const youtubeStart = 920;    // segundo desde donde arranca
const youtubeDuration = 30000; // milisegundos antes de volver a arrancar
// ────────────────────────────────────────────────────────────────────────
---

<Layout title="Los Conjuntos — Ciudad de Perros">
  <!-- NAV -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-5 bg-brand-dark/80 backdrop-blur-sm border-b border-white/5"
  >
    <a
      href="/"
      class="grid grid-cols-3 gap-x-2 font-display font-black text-brand-logo uppercase text-sm leading-tight w-fit"
    >
      <span class="text-center">L</span><span class="text-center">O</span><span
        class="text-center">S</span
      >
      <span class="text-center">C</span><span class="text-center">O</span><span
        class="text-center">N</span
      >
      <span class="text-center">J</span><span class="text-center">U</span><span
        class="text-center">N</span
      >
      <span class="text-center">T</span><span class="text-center">O</span><span
        class="text-center">S</span
      >
    </a>
    <div class="flex items-center gap-5">
      <div class="hidden md:flex items-center gap-4">
        {
          socials.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="text-white/40 hover:text-white transition-colors"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={s.icon} />
              </svg>
            </a>
          ))
        }
      </div>
      <a
        href="/sitio"
        class="text-white/60 hover:text-white text-xs tracking-widest uppercase transition-colors"
        >← Ir al sitio</a
      >
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">

    {launched ? (
      <!-- YouTube background -->
      <div class="yt-bg-wrap">
        <div id="yt-bg-player" class="yt-bg-iframe" />
        <div class="absolute inset-0" />
      </div>
    ) : (
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(232,128,0,0.12)_0%,_transparent_70%)]" />
    )}

    <div class="absolute inset-0 bg-[linear-gradient(to_bottom,_transparent_60%,_#0A0A0A_100%)]" />

    {launched ? (
      <!-- Launched: solo botón -->
      <div class="relative z-10">
        <a
          href={youtubeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-10 py-5 bg-brand-red text-white text-2xl tracking-widest uppercase hover:bg-brand-logo transition-colors"
        >
          Miralo ahora
        </a>
      </div>
    ) : (
      <div class="relative z-10 max-w-4xl mx-auto grid grid-cols-2 items-center gap-16 md:gap-24">
        <!-- Live Session -->
        <div class="text-right">
          <p class="text-brand-red text-xs tracking-[0.5em] uppercase mb-2">Live Session</p>
          <p class="text-brand-logo/40 text-xs tracking-[0.4em] uppercase">Primero de Mayo</p>
        </div>
        <!-- Ciudad de Perros -->
        <h1 class="grid grid-cols-3 gap-x-[0.2em] font-display font-light text-[clamp(2rem,6vw,5rem)] leading-none uppercase text-brand-logo w-fit justify-self-start">
          <span class="text-center">C</span><span class="text-center">I</span><span class="text-center">U</span>
          <span class="text-center">D</span><span class="text-center">A</span><span class="text-center">D</span>
          <span class="invisible">C</span><span class="text-center">D</span><span class="text-center">E</span>
          <span class="text-center">P</span><span class="text-center">E</span><span class="text-center">R</span>
          <span class="text-center">R</span><span class="text-center">O</span><span class="text-center">S</span>
        </h1>
        <div
            id="countdown"
            class="col-span-2 flex gap-2 md:gap-12 justify-center"
          >
            <div class="flex flex-col items-center">
              <span
                id="days"
                class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-logo tabular-nums"
              >
                --
              </span>
              <span class="text-brand-logo/30 text-xs tracking-widest uppercase mt-2">
                Días
              </span>
            </div>
            <span class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-red/40 leading-none">
              :
            </span>
            <div class="flex flex-col items-center">
              <span
                id="hours"
                class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-logo tabular-nums"
              >
                --
              </span>
              <span class="text-brand-logo/30 text-xs tracking-widest uppercase mt-2">
                Horas
              </span>
            </div>
            <span class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-red/40 leading-none">
              :
            </span>
            <div class="flex flex-col items-center">
              <span
                id="minutes"
                class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-logo tabular-nums"
              >
                --
              </span>
              <span class="text-brand-logo/30 text-xs tracking-widest uppercase mt-2">
                Min
              </span>
            </div>
            <span class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-red/40 leading-none">
              :
            </span>
            <div class="flex flex-col items-center">
              <span
                id="seconds"
                class="font-display text-[clamp(1.75rem,8vw,4.5rem)] text-brand-logo tabular-nums"
              >
                --
              </span>
              <span class="text-brand-logo/30 text-xs tracking-widest uppercase mt-2">
                Seg
              </span>
            </div>
          </div>
        </div>
      )}
  </section>

  <!-- PERROS -->
  <section class="py-20">
    <div class="mb-10 text-center px-6">
      <p class="text-brand-red text-sm tracking-[0.4em] uppercase mb-3">
        Los Perros de la Ciudad
      </p>
    </div>
    <div class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-y-0 left-0 w-24 z-10 bg-gradient-to-r from-brand-dark to-transparent"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 w-24 z-10 bg-gradient-to-l from-brand-dark to-transparent"
      >
      </div>
      <div class="dogs-track flex py-4">
        {
          [...dogs, ...dogs].map((dog) =>
            dog.src ? (
              <div class="relative shrink-0 w-48 aspect-[5/6] overflow-hidden group">
                <img
                  src={dog.src}
                  alt={dog.label ?? ""}
                  class="w-full h-full object-cover object-bottom transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-black/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <p class="text-brand-red text-xl font-light tracking-widest uppercase font-display text-center px-3">
                    {dog.label}
                  </p>
                </div>
              </div>
            ) : (
              <div class="shrink-0 w-48 aspect-[5/6] bg-brand-dark flex items-center justify-center">
                <span class="text-white/20 tracking-[0.5em] text-sm">...</span>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- REELS DE INSTAGRAM -->
  <section class="py-24 px-6 bg-brand-gray">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 text-center">
        <p class="text-brand-red text-sm tracking-[0.4em] uppercase mb-3">
          Camino a CIUDAD DE PERROS
        </p>
      </div>

      {
        reels.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
            {reels.map((reel) => (
              <div class="bg-brand-dark border border-white/5 overflow-hidden">
                {reel.youtube ? (
                  <div class="relative w-full aspect-[9/16]">
                    <iframe
                      src={`https://www.youtube.com/embed/${reel.youtube}?autoplay=1&mute=1&loop=1&playlist=${reel.youtube}&controls=0&modestbranding=1&playsinline=1&rel=0&showinfo=0`}
                      allow="autoplay; encrypted-media"
                      class="absolute inset-0 w-full h-full"
                    />
                    <div class="absolute inset-0" />
                  </div>
                ) : (
                  <video
                    src={reel.src}
                    autoplay
                    muted
                    loop
                    playsinline
                    class="w-full aspect-[9/16] object-cover"
                  />
                )}
                {reel.title && (
                  <p class="px-4 py-3 text-brand-logo/40 text-xs tracking-widest uppercase">
                    {reel.title}
                  </p>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="py-16 border border-white/10 text-center">
            <p class="font-display text-3xl uppercase text-brand-logo/20 tracking-widest">
              Próximamente
            </p>
            <p class="text-brand-logo/30 text-sm mt-3">
              Los videos van a aparecer acá
            </p>
          </div>
        )
      }
    </div>
  </section>

  <style is:global>
    .yt-bg-wrap {
      position: absolute;
      top: 1.5rem;
      left: 0;
      right: 0;
      bottom: 0;
      overflow: hidden;
      pointer-events: none;
    }
    .yt-bg-iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100vw;
      height: 56.25vw;
      min-height: 100vh;
      min-width: 177.78vh;
      transform: translate(-50%, -50%);
      border: none;
    }
    .dogs-track {
      width: max-content;
      cursor: grab;
    }
    .dogs-track.dragging {
      cursor: grabbing;
    }
  </style>

  <!-- FOOTER -->
  <footer
    class="py-8 px-6 border-t border-white/5 text-center text-brand-logo/20 text-xs tracking-widest uppercase"
  >
    <p>© 2026 Los Conjuntos. Todos los derechos reservados.</p>
  </footer>

  <script define:vars={{ youtubeId, youtubeStart, youtubeDuration, launched }} is:inline>
    if (launched && document.getElementById('yt-bg-player')) {
      var tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);

      var ytPlayer;
      window.onYouTubeIframeAPIReady = function () {
        ytPlayer = new YT.Player('yt-bg-player', {
          videoId: youtubeId,
          playerVars: {
            autoplay: 1, mute: 1, controls: 0,
            playsinline: 1, rel: 0, showinfo: 0,
          },
          events: {
            onReady: function (e) {
              e.target.seekTo(youtubeStart);
              e.target.playVideo();
              setInterval(function () { ytPlayer.seekTo(youtubeStart); }, youtubeDuration);
            },
          },
        });
      };
    }
  </script>

  <script>
    const track = document.querySelector('.dogs-track') as HTMLElement;
    if (track) {
      const halfWidth = track.scrollWidth / 2;
      let pos = 0;
      let dragging = false;
      let lastX = 0;

      // Auto-scroll loop
      function tick() {
        if (!dragging) {
          pos += 1.5;
          if (pos >= halfWidth) pos -= halfWidth;
        }
        track.style.transform = `translateX(${-pos}px)`;
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);

      // Mouse drag
      track.addEventListener('mousedown', (e) => {
        dragging = true;
        lastX = e.clientX;
        track.classList.add('dragging');
      });
      window.addEventListener('mousemove', (e) => {
        if (!dragging) return;
        pos -= e.clientX - lastX;
        if (pos < 0) pos += halfWidth;
        if (pos >= halfWidth) pos -= halfWidth;
        lastX = e.clientX;
      });
      window.addEventListener('mouseup', () => {
        dragging = false;
        track.classList.remove('dragging');
      });

    }
  </script>

  <script define:vars={{ launchDate: LAUNCH_DATE.toISOString(), launched }}>
    if (!launched) {
      function updateCountdown() {
        const now = new Date();
        const target = new Date(launchDate);
        const diff = target - now;

        if (diff <= 0) {
          document.getElementById("countdown").innerHTML =
            '<p class="font-display text-4xl uppercase text-brand-red tracking-widest">¡Ya salió!</p>';
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
          (diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        const pad = (n) => String(n).padStart(2, "0");
        document.getElementById("days").textContent = pad(days);
        document.getElementById("hours").textContent = pad(hours);
        document.getElementById("minutes").textContent = pad(minutes);
        document.getElementById("seconds").textContent = pad(seconds);
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    }
  </script>
</Layout>
