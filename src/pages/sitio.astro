---
import Layout from "../layouts/Layout.astro";
import { socials, releases } from "../config";
---

<Layout>
  <!-- NAV -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-5 bg-brand-dark/80 backdrop-blur-sm border-b border-white/5"
  >
    <a
      href="/sitio"
      class="grid grid-cols-3 gap-x-2 font-display font-black text-brand-logo uppercase text-sm leading-tight w-fit"
    >
      <span class="text-center">L</span><span class="text-center">O</span><span
        class="text-center">S</span
      >
      <span class="text-center">C</span><span class="text-center">O</span><span
        class="text-center">N</span
      >
      <span class="text-center">J</span><span class="text-center">U</span><span
        class="text-center">N</span
      >
      <span class="text-center">T</span><span class="text-center">O</span><span
        class="text-center">S</span
      >
    </a>
    <div class="flex items-center gap-6">
      <ul
        class="hidden md:flex gap-8 text-sm tracking-widest uppercase text-white/60"
      >
        <li>
          <a href="#musica" class="hover:text-white transition-colors">Música</a
          >
        </li>
        <li>
          <a href="#merch" class="hover:text-white transition-colors">Kiosco</a>
        </li>
        <li>
          <a href="#banda" class="hover:text-white transition-colors">Banda</a>
        </li>
      </ul>
      <div class="hidden md:flex items-center gap-4">
        {
          socials.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="text-white/40 hover:text-white transition-colors"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={s.icon} />
              </svg>
            </a>
          ))
        }
      </div>
      <a
        href="/lanzamiento"
        class="text-brand-red hover:text-white text-sm tracking-widest uppercase transition-colors"
        >SESIÓN EN VIVO</a
      >
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen overflow-hidden">
    <!-- Frame animation -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/frames-tomate/hero.mp4" type="video/mp4" />
    </video>
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_bottom,_transparent_50%,_#0A0A0A_100%)]"
    >
    </div>

    <!-- Logo centrado encima -->
    <div
      class="relative z-10 min-h-screen flex flex-col items-center justify-center text-center px-6"
    >
      <h1
        class="grid grid-cols-3 gap-x-[0.6em] font-display font-black text-[clamp(2rem,6vw,5rem)] leading-none uppercase text-brand-logo w-fit mx-auto"
      >
        <span class="text-center">L</span><span class="text-center">O</span
        ><span class="text-center">S</span>
        <span class="text-center">C</span><span class="text-center">O</span
        ><span class="text-center">N</span>
        <span class="text-center">J</span><span class="text-center">U</span
        ><span class="text-center">N</span>
        <span class="text-center">T</span><span class="text-center">O</span
        ><span class="text-center">S</span>
      </h1>
      <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#musica"
          class="px-8 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-white/60 hover:text-white transition-colors"
        >
          Escuchar
        </a>
        <a
          href="#merch"
          class="px-8 py-3 bg-brand-red text-white text-sm tracking-widest uppercase hover:bg-brand-logo transition-colors"
        >
          Ver Kiosco
        </a>
      </div>
    </div>

    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        class="text-white/30"
      >
        <path d="M12 5v14M5 12l7 7 7-7"></path>
      </svg>
    </div>
  </section>

  <!-- MÚSICA -->
  <section id="musica" class="py-32 px-6 bg-brand-gray">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <p class="text-brand-red text-xs tracking-[0.4em] uppercase mb-4">
          Discografía
        </p>
        <h2 class="font-display text-5xl md:text-6xl uppercase leading-none">
          Música
        </h2>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {
          releases.map((release) => (
            <a
              href={release.spotify}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-brand-dark border border-white/5 hover:border-brand-red/30 transition-colors overflow-hidden"
            >
              <div class="aspect-square overflow-hidden">
                <img
                  src={release.image}
                  alt={release.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-5 flex items-center justify-between">
                <div>
                  <p class="text-brand-red text-xs tracking-widest uppercase mb-1">
                    {release.type}
                  </p>
                  <h3 class="font-display text-xl uppercase">
                    {release.title}
                  </h3>
                </div>
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-white/20 group-hover:text-brand-red transition-colors shrink-0 ml-4"
                >
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- KIOSCO -->
  <section id="merch" class="py-32 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <p class="text-brand-red text-xs tracking-[0.4em] uppercase mb-4">
          2026
        </p>
        <h2 class="font-display text-5xl md:text-6xl uppercase leading-none">
          Kiosco
        </h2>
      </div>
      <div class="py-16 border border-white/10 text-center">
        <p
          class="font-display text-3xl uppercase text-white/20 tracking-widest"
        >
          Próximamente
        </p>
      </div>
    </div>
  </section>

  <!-- BANDA & CONTACTO -->
  <section id="banda" class="py-32 px-6 bg-brand-gray">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-brand-red text-xs tracking-[0.4em] uppercase mb-4">
          La Banda
        </p>
        <h2
          class="font-display text-5xl md:text-6xl uppercase leading-none mb-8"
        >
          Quiénes<br />somos
        </h2>
        <div class="space-y-4 text-white/60 leading-relaxed">
          <p>Banda platense, creadores del Rock Fútbol</p>
        </div>
        <div class="mt-10 pt-10 border-t border-white/10">
          <p class="text-brand-red text-xs tracking-[0.4em] uppercase mb-6">
            Seguinos
          </p>
          <div class="flex flex-wrap gap-6">
            {
              socials.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.name}
                  class="text-white/40 hover:text-white transition-colors"
                >
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d={s.icon} />
                  </svg>
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <div
        class="relative aspect-square bg-brand-gray rounded-sm overflow-hidden"
      >
        <img
          src="/foto-banda.png"
          alt="Los Conjuntos"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer
    class="py-8 px-6 border-t border-white/5 text-center text-white/20 text-xs tracking-widest uppercase"
  >
    <p>© 2026 Los Conjuntos. Todos los derechos reservados.</p>
  </footer>

  <script>
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.querySelector(
          anchor.getAttribute("href") as string,
        );
        if (target) target.scrollIntoView({ behavior: "smooth" });
      });
    });
  </script>
</Layout>
